# Shared with AOTC-DB — same Postgres instance, different schemas.
DATABASE_URL=postgresql://aotc:CHANGEME@localhost:5432/aotc

# Where this repo stores raw article bodies, state files, locks.
# Kept separate from AOTC-DB's /opt/db so the two repos don't collide.
DB_BASE=/opt/db-signals

PYTHONUNBUFFERED=1

# ── Phase 1: ingesters ─────────────────────────────────────────────────────
# Alpha Vantage — drives news_alpha_vantage.py and macro_alpha_vantage.py.
# Free tier = 25 calls/day; premium tiers run from 75/min upward.
# Sign up at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Optional overrides for news_alpha_vantage.py live mode. If AV_NEWS_TICKERS
# is set, we filter the API call to those symbols and ignore AV_NEWS_TOPICS.
# AV_NEWS_TICKERS=AAPL,MSFT,NVDA,SPY
# AV_NEWS_TOPICS=financial_markets,economy_macro,economy_monetary
# AV_NEWS_LOOKBACK_HOURS=24

# X (Twitter) v2 — required by social_twitter.py. Without it, the ingester
# exits cleanly with a one-line log message and does nothing.
# Basic plan ($200/mo) covers /tweets/search/recent at 60 req / 15 min.
# Pro plan ($5,000/mo) is needed for the filtered-stream low-latency path.
TWITTER_BEARER_TOKEN=

# Override the X API host if your tier uses api.x.com instead of api.twitter.com.
# TWITTER_API_BASE=https://api.twitter.com

# ── Phase 3: fast signal + paper trading ───────────────────────────────────
# Notional book size for paper-trade sizing. qty per fill = max_position_pct
# × PORTFOLIO_NOTIONAL × confidence / entry_price.
PORTFOLIO_NOTIONAL=100000

# Synthetic slippage applied to every paper fill, in basis points.
# 5 = 0.05% — realistic for liquid US large-caps in normal market hours.
# Increase if your watchlist trends small-cap or you want a conservative test.
BPS_SLIPPAGE=5

# ── Phase 4: slow LangGraph agent ──────────────────────────────────────────
# Anthropic key powers the slow agent's multi-step debate and the Phase-2
# LLM ticker-resolution fallback. Without it, the slow path is disabled and
# the fast path is the only writer to signals.decisions.
ANTHROPIC_API_KEY=

# Two-tier model config. The fast model runs in analyst leaves where there
# are many cheap calls; the deep model runs at the bull/bear judges and the
# portfolio manager where reasoning quality matters most.
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_DEEP_MODEL=claude-sonnet-4-6

# Per-decision LangGraph caps. 1 = one bull + one bear round before the
# research manager rules. Bumping to 2 doubles tokens; rarely worth it
# unless backtest shows the agent flip-flopping.
MAX_DEBATE_ROUNDS=1
MAX_RISK_DISCUSS_ROUNDS=1

# Master switch — set to "false" to disable slow-path dispatch entirely
# (e.g. during cost-sensitive backtests where you only want fast-path output).
SLOW_AGENT_ENABLED=true

# How many same-ticker and cross-ticker reflections to inject into the
# manager's prompt. Mirrors TradingAgents' get_past_context() retrieval.
PAST_CONTEXT_SAME_TICKER=5
PAST_CONTEXT_CROSS_TICKER=3

# ── Phase 5: paper-jobs scheduler (trader/paper/run.py) ────────────────────
# Tick cadences. Smaller = lower latency, more DB load.
MTM_INTERVAL_SEC=60
SUPERSEDE_INTERVAL_SEC=60
SETTLE_INTERVAL_SEC=300
REFLECT_INTERVAL_SEC=600

# Cap on mtm_history rows kept per open position. ~24h of 60s marks fits in
# 1440. Cranking down loses analysis depth but keeps mtm_history small on
# wide watchlists.
MTM_HISTORY_PER_POSITION=1440

# Slow-supersession aggressiveness:
# If a slow decision agrees in direction with the fast call but its confidence
# is at least this much *lower*, the fast position is closed early to de-risk.
# 0.30 = "the slow agent is 30 confidence points less convinced than fast".
SUPERSEDE_DOWNGRADE_DELTA=0.30

# Reflect batch cap per tick (one LLM call per decision row in the batch).
REFLECT_BATCH_LIMIT=25

# ── Tracked-handle theme inference (trader/social_inference.py) ────────────
# Minimum LLM confidence for a watchlist pick to become a decision. Lower =
# more decisions but more noise (the slow agent will still review them).
SOCIAL_INFERENCE_CONFIDENCE_FLOOR=0.40

# Hard cap on tickers per inferred post. The LLM is told to sort descending
# by confidence, so this also caps the worst-confidence ones out first.
SOCIAL_INFERENCE_MAX_PICKS=5
